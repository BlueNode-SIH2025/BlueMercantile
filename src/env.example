# BlueMercantile Web3 Configuration
# Copy this file to .env and update the values with your deployed contract information

# Deployed BlueCarbonToken contract address on Sepolia testnet
# You'll get this after deploying the contract using Remix IDE
NEXT_PUBLIC_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# Sepolia testnet RPC URL (optional - MetaMask provides this automatically)
# You can get a free RPC URL from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Optional: Etherscan API key for transaction verification
# Get from: https://etherscan.io/apis
NEXT_PUBLIC_ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Network Configuration (do not change)
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_NETWORK_NAME=Sepolia Test Network

# Contract Owner Address (the address that deployed the contract)
# This address has minting privileges
NEXT_PUBLIC_OWNER_ADDRESS=0x0000000000000000000000000000000000000000